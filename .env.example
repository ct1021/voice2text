# 把本文件复制为 .env，填入你的 API key。
#     copy .env.example .env   (Windows)
#     cp .env.example .env     (macOS)
# .env 已被 .gitignore 排除，不会上传到 GitHub。
# 仅当 config.toml 的 AI 后端用到 API key 时才需要填。

# DeepSeek（config [ai] backend = "openai-compatible" 时用）
DEEPSEEK_API_KEY=

# Anthropic（config [ai] backend = "anthropic-api" 时用）
ANTHROPIC_API_KEY=
